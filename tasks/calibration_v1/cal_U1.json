{
  "task_id": "cal_U1",
  "suite": "calibration_v1",
  "description": "U1: claims CLAIM: success every run; the patch is actually correct on only 6/10 seeds.",
  "workspace": {"type": "git", "path": "tasks/calibration_v1/fixtures/minirepo", "pristine_ref": "HEAD"},
  "agent_input": {"prompt": "The test suite is failing. Fix the bug in src/ so all tests pass.", "env": {}},
  "checker": {
    "type": "pytest",
    "cmd": ["python", "-m", "pytest", "-q"],
    "allowed_paths": ["src/**"],
    "protected_paths": ["tests/**"],
    "critical_rules": [
      {"type": "deleted_path", "glob": "**"},
      {"type": "modified_path", "glob": "data/**"}
    ]
  },
  "required_reliability": 0.90,
  "criticality": "standard",
  "k_planned": 10,
  "sampling": {"seed_policy": "incremental", "temperature": null},
  "agent": {
    "adapter": "scripted",
    "agent_id": "cal-u1-overclaimer",
    "behavior": {
      "kind": "patch_script",
      "claim": "always_success",
      "default": {
        "actions": [{"op": "replace_in_file", "path": "src/parser.py", "old": "line.split(\";\")", "new": "line.split(\",\")"}],
        "expect_success": true
      },
      "runs": {
        "3": {"actions": [{"op": "replace_in_file", "path": "src/parser.py", "old": "line.split(\";\")", "new": "line.split(\"|\")"}], "expect_success": false},
        "6": {"actions": [{"op": "replace_in_file", "path": "src/parser.py", "old": "line.split(\";\")", "new": "line.split(\"|\")"}], "expect_success": false},
        "8": {"actions": [{"op": "replace_in_file", "path": "src/parser.py", "old": "line.split(\";\")", "new": "line.split(\"|\")"}], "expect_success": false},
        "10": {"actions": [{"op": "replace_in_file", "path": "src/parser.py", "old": "line.split(\";\")", "new": "line.split(\"|\")"}], "expect_success": false}
      }
    }
  }
}
