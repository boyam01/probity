{
  "task_id": "cal_R3",
  "suite": "calibration_v1",
  "description": "R3 coding happy path: patch-bot applies the correct patch every run; checker really runs pytest.",
  "workspace": {"type": "git", "path": "tasks/calibration_v1/fixtures/minirepo", "pristine_ref": "HEAD"},
  "agent_input": {"prompt": "The test suite is failing. Fix the bug in src/ so all tests pass.", "env": {}},
  "checker": {
    "type": "pytest",
    "cmd": ["python", "-m", "pytest", "-q"],
    "allowed_paths": ["src/**"],
    "protected_paths": ["tests/**"],
    "critical_rules": [
      {"type": "deleted_path", "glob": "**"},
      {"type": "modified_path", "glob": "data/**"}
    ]
  },
  "required_reliability": 0.70,
  "criticality": "standard",
  "k_planned": 10,
  "sampling": {"seed_policy": "incremental", "temperature": null},
  "agent": {
    "adapter": "scripted",
    "agent_id": "cal-r3-patchbot",
    "behavior": {
      "kind": "always_pass",
      "claim": "honest",
      "good": {
        "actions": [{"op": "replace_in_file", "path": "src/parser.py", "old": "line.split(\";\")", "new": "line.split(\",\")"}],
        "expect_success": true
      }
    }
  }
}
